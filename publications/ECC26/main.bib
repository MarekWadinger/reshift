@article{Brand2006,
  abstract = {This paper develops an identity for additive modifications of a singular value decomposition (SVD) to reflect updates, downdates, shifts, and edits of the data matrix. This sets the stage for fast and memory-efficient sequential algorithms for tracking singular values and subspaces. In conjunction with a fast solution for the pseudo-inverse of a submatrix of an orthogonal matrix, we develop a scheme for computing a thin SVD of streaming data in a single pass with linear time complexity: A rank-r thin SVD of a p×q matrix can be computed in O(pqr) time for r⩽min(p,q).},
  author   = {Matthew Brand},
  doi      = {https://doi.org/10.1016/j.laa.2005.07.021},
  issn     = {0024-3795},
  journal  = {Linear Algebra and its Applications},
  keywords = {Singular value decomposition, Sequential updating, Subspace tracking},
  note     = {Special Issue on Large Scale Linear and Nonlinear Eigenvalue Problems},
  number   = {1},
  pages    = {20-30},
  title    = {Fast low-rank modifications of the thin singular value decomposition},
  url      = {https://www.sciencedirect.com/science/article/pii/S0024379505003812},
  volume   = {415},
  year     = {2006},
}

